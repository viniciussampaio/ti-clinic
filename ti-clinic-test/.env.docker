NODE_ENV=development
# Porta do Nest dentro do container (nao confundir com API_PORT_EXPOSE).
PORT=3000
# Porta no Windows/Mac onde a API fica acessivel (altere se 3000 estiver ocupada).
API_PORT_EXPOSE=3001
# MySQL no host — evita conflito com MySQL local na 3306.
DB_PORT_EXPOSE=3307

# Database (docker-compose overrides DB_HOST/DB_PORT)
DB_DATABASE=clinic
DB_USERNAME=root
DB_PASSWORD=root

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8080

